{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ChunkResult",
  "title": "ChunkResult",
  "type": "object",
  "properties": {
    "chunkingId": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "tokens": {
            "type": "integer"
          },
          "index": {
            "type": "integer"
          }
        }
      }
    }
  }
}